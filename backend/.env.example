# ===========================================
# OpenIssue Backend Configuration
# ===========================================
# Copy this file to .env and fill in values

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Gemini API (Required for AI features)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_TIMEOUT_SECS=12

# GitHub API (Required for /repos endpoints)
# Create a PAT at: https://github.com/settings/tokens
# Scopes needed: repo (or fine-grained: Contents + Pull requests read/write)
GITHUB_TOKEN=

# GitHub OAuth (Optional - for user login flow)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback
FRONTEND_URL=http://localhost:3000

# Firebase Authentication (Optional - for protected endpoints)
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=

# Vector Storage
SIMILARITY_MODE=chromadb

# Legacy / fallback settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
TOP_K_SIMILAR=5
SIMILARITY_THRESHOLD=0.5
